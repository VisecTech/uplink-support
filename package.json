{
  "name": "uplink-support",
  "version": "0.1.0",
  "description": "Uplink Web Services — standalone support / help-desk (support.uplink.net.au)",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3081",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3081",
    "type-check": "tsc --noEmit",
    "postbuild": "scripts/post-build.sh",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- tsx scripts/migrate.ts",
    "staff:create": "dotenv -e .env.local -- tsx scripts/create-staff.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "imapflow": "^1.4.2",
    "isomorphic-dompurify": "^3.14.0",
    "mailparser": "^3.9.11",
    "marked": "^18.0.3",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
